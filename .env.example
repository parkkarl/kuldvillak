# Kopeeri see fail nimega .env. Kõik valikud on optionaalsed.
# Allikate prioriteet: ANTHROPIC_API_KEY > Claude CLI > mock.

# --- Variant 1: Anthropic API (eraldi võti, makstakse Anthropic'ule) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Variant 2: Claude Code CLI (sinu Claude Pro/Max tellimuse kaudu) ---
# Kui Hetzneri serverisse on paigaldatud Claude Code (https://claude.com/code)
# ja sa oled sisse logitud (`claude /login`), siis tuvastab rakendus selle
# automaatselt ja iga küsimus läheb läbi sinu CLI seansi — API võtit pole vaja.
# Allpool olevad muutujad on valikulised:
# CLAUDE_CLI_BIN=claude                  # binaari nimi/tee, vaikimisi 'claude'
# CLAUDE_CLI_MODEL=claude-sonnet-4-6     # mudel, mida CLI-ga kasutada
# CLAUDE_CLI_TIMEOUT_MS=240000           # kui kaua oodata vastust (vaikimisi 4 min)
# USE_CLAUDE_CLI=true                    # forsseeri CLI, isegi kui API_KEY on seatud
# USE_CLAUDE_CLI=false                   # keela CLI tuvastus täielikult

# --- Variant 3: Mock-režiim ---
# Jäta mõlemad ülemised seadmata. Rakendus genereerib 15 demoküsimust malli
# põhjal — sobib UI ja mängumehhaanika kontrollimiseks.

# --- Üldine ---
PORT=3000
