# Kopeeri see fail nimega .env ja sisesta enda Anthropic API votme
# Kui votmet pole, kasutab rakendus mock-kusimusi (sama valjanagemine, ainult sisu on lihtsustatud)
ANTHROPIC_API_KEY=

# Vaikemudel kusimuste genereerimiseks
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server port (vaikimisi 3000)
PORT=3000
